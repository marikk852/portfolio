# ===========================================
# PostgreSQL (обязательно для Vercel)
# ===========================================
# Для Vercel Postgres: добавьте БД в Storage → скопируйте POSTGRES_PRISMA_URL и POSTGRES_URL_NON_POOLING
# Для Neon: https://neon.tech — бесплатный tier
# Для Supabase: https://supabase.com — бесплатный tier
#
# DATABASE_URL — основной URL (с pooling для Neon/Vercel)
# DIRECT_DATABASE_URL — прямой URL для миграций (без pooling). Если один URL — укажите тот же.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ===========================================
# NextAuth
# ===========================================
NEXTAUTH_SECRET="your-secret-key-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# Админка (для seed)
# ===========================================
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"

# ===========================================
# Telegram (форма контактов)
# ===========================================
TELEGRAM_BOT_TOKEN="your_bot_token_from_botfather"
TELEGRAM_CHAT_ID="your_chat_id"
